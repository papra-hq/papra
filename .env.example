# =============================================================================
# Papra – Example environment file
# =============================================================================
# Copy this file to `.env` and fill in the values for your deployment:
#
#   cp .env.example .env
#
# Docker Compose automatically loads `.env` next to the compose file – no
# extra flags needed. For multiple environments use:
#
#   docker compose --env-file .env.prod up -d
#
# Only the values you actually want to override need to be set – everything
# else falls back to Papra's defaults. See the full reference at:
#   https://docs.papra.app/self-hosting/configuration
# =============================================================================


# -----------------------------------------------------------------------------
# Core (required)
# -----------------------------------------------------------------------------

# Secret used to sign auth tokens. MUST be at least 32 characters.
# Generate one with:  openssl rand -hex 48
AUTH_SECRET=change-me-generate-with-openssl-rand-hex-48

# Public base URL of the application (scheme + host + optional port).
# When Papra sits behind a reverse proxy / domain, set this accordingly,
# e.g. https://papra.example.com
APP_BASE_URL=http://localhost:1221

# Host port that will be published on the docker host.
# The container always listens internally on 1221.
PAPRA_HOST_PORT=1221


# -----------------------------------------------------------------------------
# Auth (optional)
# -----------------------------------------------------------------------------

# Disable public registration once your account(s) have been created.
# AUTH_IS_REGISTRATION_ENABLED=false

# Require users to verify their email address before logging in.
# Needs a working email driver (see "Emails" below).
# AUTH_IS_EMAIL_VERIFICATION_REQUIRED=false

# Header your reverse proxy uses to forward the real client IP.
# Standard proxies: x-forwarded-for   |   Cloudflare: cf-connecting-ip
# AUTH_IP_ADDRESS_HEADERS=x-forwarded-for


# -----------------------------------------------------------------------------
# Documents (optional)
# -----------------------------------------------------------------------------

# Maximum upload size in bytes (default: 26214400 = 25 MiB). 0 = unlimited.
# DOCUMENT_STORAGE_MAX_UPLOAD_SIZE=26214400

# OCR languages, comma separated. See:
# https://tesseract-ocr.github.io/tessdoc/Data-Files
# DOCUMENTS_OCR_LANGUAGES=eng,deu


# -----------------------------------------------------------------------------
# Emails / SMTP (optional)
# -----------------------------------------------------------------------------
# Default driver is "logger" (emails are only logged, not sent).
# Set to "smtp" and fill in the credentials to actually send emails.

# EMAILS_DRIVER=smtp
# EMAILS_FROM_ADDRESS=Papra <papra@example.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false


# -----------------------------------------------------------------------------
# OAuth providers (optional)
# -----------------------------------------------------------------------------

# AUTH_PROVIDERS_GITHUB_IS_ENABLED=false
# AUTH_PROVIDERS_GITHUB_CLIENT_ID=
# AUTH_PROVIDERS_GITHUB_CLIENT_SECRET=

# AUTH_PROVIDERS_GOOGLE_IS_ENABLED=false
# AUTH_PROVIDERS_GOOGLE_CLIENT_ID=
# AUTH_PROVIDERS_GOOGLE_CLIENT_SECRET=
