{
  "name": "@papra/root",
  "version": "0.3.0",
  "description": "Papra document management monorepo root",
  "keywords": [],
  "license": "AGPL-3.0-or-later",
  "author": "Corentin Thomasset <corentinth@proton.me> (https://corentin.tech)",
  "type": "module",
  "scripts": {
    "version": "changeset version && pnpm install --no-frozen-lockfile",
    "changeset": "changeset",
    "build:packages": "pnpm --filter './packages/*' --stream build",
    "build:packages:watch": "pnpm --filter './packages/*' --stream build:watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check": "oxlint && oxfmt --check",
    "check:quiet": "oxlint --quiet && oxfmt --check",
    "check:fix": "oxlint --fix && oxfmt",
    "lint": "pnpm run check",
    "lint:fix": "pnpm run check:fix"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.1.1"
}
